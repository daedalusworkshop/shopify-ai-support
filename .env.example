# Anthropic — required
ANTHROPIC_API_KEY=sk-ant-...

# Shopify webhook HMAC verification — optional, skipped in dev
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# Per-store API keys for /messages endpoint (JSON) — optional, skipped in dev
STORE_API_KEYS={"mystore.myshopify.com":"sk_live_abc123"}

# Per-store Shopify Admin access tokens for order lookups (JSON) — optional
SHOPIFY_ACCESS_TOKENS={"mystore.myshopify.com":"shpat_xxx"}

# Server
PORT=3000
